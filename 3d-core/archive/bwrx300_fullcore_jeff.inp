uF2B   uR
uR   uR

surf s22_1RNE  sqc  0.0 0.0 15.85
cell c22_1RNE  uF22RNE  fill  uBundleRNE -s22_1RNE 

% -------------------------------------------------------------------
% 2x2 cluster - 2D - Unrodded with Refl, to be placed in core on South East side
% -------------------------------------------------------------------
lat uBundleRSE  1 0.0  0.0 2 2 15.85
uR   uR
uR  uF2B

surf s22_1RSE  sqc  0.0 0.0 15.85
cell c22_1RSE  uF22RSE  fill  uBundleRSE -s22_1RSE 

% -------------------------------------------------------------------
% 2x2 cluster - 2D - Unrodded with Refl, to be placed in core on South West side
% -------------------------------------------------------------------
lat uBundleRSW  1 0.0  0.0 2 2 15.85
uR   uR
uF1B uR

surf s22_1RSW  sqc  0.0 0.0 15.85
cell c22_1RSW  uF22RSW  fill  uBundleRSW -s22_1RSW 

% -------------------------------------------------------------------
% 2x2 cluster - 2D - Reflector bundle
% -------------------------------------------------------------------
lat uBundleRR  1 0.0  0.0 2 2 15.85
uR   uR
uR   uR

surf s22_1RR  sqc  0.0 0.0 15.85
cell c22_1RR  u22RR  fill  uBundleRR -s22_1RR 


% -------------------------------------------------------------------
% 2x2 cluster - 2D - Rodded
% -------------------------------------------------------------------
lat uBundleR  1 0.0  0.0 2 2 15.85
uF2B uF1B
uF1B uF2B

surf s22_1R sqc   0.0 0.0 15.85
surf sCR    cross 0.0 0.0 12.950 0.50 

cell c22_1R  uF22R  fill  uBundle -s22_1R sCR  
cell c2_CR   uF22R  fill uCR      -sCR 

% -------------------------------------------------------------------
% CR blade 
% -------------------------------------------------------------------
% -- Control Blade %
surf sCRB cross 0.0       0.0 12.950 0.50 

